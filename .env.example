# =============================================================================
# AetherBlog Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# All variables marked (REQUIRED) must be set for production deployment.
# =============================================================================

# --- Gateway ---
GATEWAY_PORT=7899

# --- PostgreSQL (REQUIRED for production) ---
POSTGRES_PASSWORD=

# --- Redis (REQUIRED for production) ---
REDIS_PASSWORD=
REDIS_HOST=redis
REDIS_PORT=6379

# --- JWT (REQUIRED for production, min 32 chars) ---
JWT_SECRET=

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:7899,http://127.0.0.1:7899

# --- Auth Cookie ---
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=Strict

# --- AI Service ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
AI_MOCK_MODE=false

# --- Docker Registry (for pulling pre-built images) ---
# DOCKER_REGISTRY=golovin0623
# VERSION=latest
