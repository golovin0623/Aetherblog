# =============================================================================
# AetherBlog Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# All variables marked (REQUIRED) must be set for production deployment.
# =============================================================================

# --- Gateway ---
GATEWAY_PORT=7899

# --- PostgreSQL (REQUIRED for production) ---
POSTGRES_PASSWORD=

# --- Redis (REQUIRED for production) ---
REDIS_PASSWORD=
REDIS_HOST=redis
REDIS_PORT=6379

# --- JWT (REQUIRED for production, min 32 chars) ---
JWT_SECRET=

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:7899,http://127.0.0.1:7899

# --- Auth Cookie ---
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=Strict

# --- Internal Service Token (REQUIRED, min 32 chars) ---
# Used for Go backend ↔ AI service inter-service authentication.
# Generate with: openssl rand -base64 48
AETHERBLOG_AI_INTERNAL_SERVICE_TOKEN=
AI_INTERNAL_SERVICE_TOKEN=

# --- AI Credential Encryption Keys (REQUIRED) ---
# VULN-056 fix: must NOT reuse JWT_SECRET. Comma-separated list of Fernet keys.
# First key is used for new encryption; all keys are tried for decryption
# (zero-downtime rotation). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AI_CREDENTIAL_ENCRYPTION_KEYS=

# --- AI Service ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
AI_MOCK_MODE=false

# --- SSRF Guard (LOCAL DEV ONLY — MUST remain unset in production) ---
# Local development behind a fake-ip proxy (Clash/Mihomo default
# fake-ip-range: 198.18.0.0/16) resolves public hostnames to 198.18.x,
# which Python's stdlib classifies as private/reserved. The SSRF guard
# in ai-service then rejects the outbound LLM call as "Provider base_url
# resolves to an internal or private network".
#
# Setting this to 1 drops the broad is_private/is_reserved heuristic and
# relies only on the explicit blocklist (RFC1918, loopback, link-local
# incl. AWS/GCP/Azure IMDS, CGNAT, v6 ULA — still fully enforced).
# AETHERBLOG_SSRF_ALLOW_RESERVED=1

# --- Docker Registry (for pulling pre-built images) ---
# DOCKER_REGISTRY=golovin0623
# VERSION=latest

# --- Container Monitoring (admin panel "容器监控") ---
# The backend container mounts /var/run/docker.sock:ro to read container
# stats for the admin monitor page. The process runs as UID 1001 (non-root),
# so it must be added to the host's docker group via group_add. Set this to
# the GID of the host's `docker` group; find it with:
#   stat -c '%g' /var/run/docker.sock
# Typical values: 999 (Ubuntu/Debian), 998 (some distros), 281 (Alpine).
# If unset, docker-compose defaults to 999.
DOCKER_GID=999
